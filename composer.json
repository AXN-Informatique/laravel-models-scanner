{
    "name": "axn/laravel-models-scanner",
    "description": "Scans Eloquent models to show some information about them.",
    "homepage": "https://github.com/AXN-Informatique/laravel-models-scanner",
    "support": {
        "issues": "https://github.com/AXN-Informatique/laravel-models-scanner/issues",
        "source": "https://github.com/AXN-Informatique/laravel-models-scanner"
    },
    "authors": [
        {
            "name": "AXN Informatique",
            "email": "developpement@axn.fr"
        }
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "doctrine/dbal": "^4.4",
        "laravel/framework": "^12.0 || ^13.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.3.0",
        "laravel/pint": "^1.29.1",
        "rector/rector": "^2.4.2"
    },
    "autoload": {
        "psr-4": {
            "Axn\\ModelsScanner\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Axn\\ModelsScanner\\ServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
